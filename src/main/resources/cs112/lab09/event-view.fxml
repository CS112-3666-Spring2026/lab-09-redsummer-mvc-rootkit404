<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cs112.lab09.controllers.EventController">
   <bottom>
      <Button fx:id="closeButton" mnemonicParsing="false" onAction="#onCloseButtonClick" text="Close" BorderPane.alignment="CENTER" />
   </bottom>
   <right>
      <BorderPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <top>
            <VBox alignment="CENTER" prefWidth="100.0" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="locationLabel" alignment="CENTER" contentDisplay="CENTER" text="Location">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                     <padding>
                        <Insets bottom="4.0" />
                     </padding>
                  </Label>
                  <Label fx:id="dateLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="10.0" layoutY="10.0" text="Date" />
               </children>
            </VBox>
         </top>
         <center>
            <VBox alignment="CENTER" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="descriptionLabel" text="Description" textAlignment="CENTER" wrapText="true">
                     <padding>
                        <Insets bottom="8.0" />
                     </padding>
                  </Label>
                  <Label fx:id="revisedDescriptionLabel" layoutX="10.0" layoutY="10.0" text="Revised Description" textAlignment="CENTER" wrapText="true">
                     <padding>
                        <Insets top="6.0" />
                     </padding>
                  </Label>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </right>
</BorderPane>
